# Clerk Authentication
# Get your key from: https://dashboard.clerk.com
# Mirror these EXPO_PUBLIC_* values into EAS environments:
# development, preview, production.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
EXPO_PUBLIC_WS_URL=http://10.0.146.134:4000
EXPO_PUBLIC_API_URL=http://10.0.146.134:4000/api/v1
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Stream Video SDK
EXPO_PUBLIC_STREAM_API_KEY=your_stream_api_key_here

# EAS secret file variables for remote builds/workflows:
# GOOGLE_SERVICES_JSON=android google-services.json
# GOOGLE_SERVICE_INFO_PLIST=ios GoogleService-Info.plist
